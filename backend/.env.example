# Copy to .env and fill in values before running locally
# In Railway/Render, set these as environment variables in the dashboard

# Required — your OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional — LLM model overrides
LLM_MODEL=stepfun/step-3.5-flash:free
FALLBACK_LLM_MODEL=minimax/minimax-m2.5:nitro

# Auth — set a strong password and secret
APP_PASSWORD=changeme_use_a_strong_password
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app

# Database — leave blank to use SQLite locally; set to Postgres URL in production
# e.g. postgresql://user:pass@host:5432/dbname  (Vercel Postgres / Neon / Supabase)
DATABASE_URL=

# Vercel deployment — set to "1" automatically by Vercel; disables APScheduler
VERCEL=

# Cron security — set a strong random string; Vercel will pass it to cron requests
CRON_SECRET=change-me-to-a-random-string
