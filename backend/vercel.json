{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python", "config": { "maxDuration": 800 } }
  ],
  "functions": {
    "main.py": {
      "maxDuration": 800,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "main.py" }
  ],
  "crons": [
    { "path": "/api/cron/debate", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/evaluate", "schedule": "30 */4 * * *" }
  ]
}
