{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/debate", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/evaluate", "schedule": "30 */4 * * *" }
  ]
}
